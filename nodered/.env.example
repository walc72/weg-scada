# =============================================================================
# WEG SCADA - Environment Variables Template
# Copy this to .env and fill in your values
# =============================================================================

# Timezone
TZ=America/Mexico_City

# Node-RED
NODE_RED_CREDENTIAL_SECRET=change-me

# InfluxDB
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-me
INFLUXDB_ORG=WEG_Monitoring
INFLUXDB_BUCKET=weg_drives
INFLUXDB_TOKEN=change-me

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me

# SMTP (configure when needed)
GF_SMTP_USER=your-email@gmail.com
GF_SMTP_PASSWORD=your-app-password
GF_SMTP_FROM=your-email@gmail.com

# Tailscale (leave empty for manual auth)
TS_AUTHKEY=
